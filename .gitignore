# ═══════════════════════════════════════════════════════════════════════
# Clover — .gitignore
# ═══════════════════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.yarn/
.npm/

# ── Build output ──────────────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# ── Runtime data (SQLite, LanceDB, local state) ──────────────────────
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.lance/

# ── Tauri ─────────────────────────────────────────────────────────────
apps/ui/src-tauri/target/
apps/ui/src-tauri/WixTools/
apps/ui/src-tauri/Frameworks/

# ── Vite / bundler cache ─────────────────────────────────────────────
.vite/
*.local

# ── Environment & secrets ─────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Logs ──────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Test & coverage ──────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/

# ── IDE / Editor ──────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# VS Code — keep shared settings, ignore personal
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# ── OS generated ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── AI tooling (local settings, not shared) ───────────────────────────
.claude/
.kiro/settings/
.kiro/
.vscode/

# ── Misc ──────────────────────────────────────────────────────────────
*.tgz
*.tar.gz
*.zip
.cache/
.temp/
.tmp/
